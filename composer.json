{
    "name": "waframe/waframe",
    "description": "WA Framework - Framework personalizado",
    "type": "library",
    "license": "MIT",
    "version": "1.0.0",
    "authors": [
        {
            "name": "WA Team",
            "email": "dev@wa.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "diogocardoso/waframe-php": "dev-main"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/diogocardoso/WAFrame-php"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "WAFrame\\": "src/",
            "WAFrame\\Factory\\": "factory/"
        }
    }
}